<%- include('partials/header', { title: 'Sign Up' }) %>

<div class="auth-wrapper">
  <div class="auth-card wide">

    <!-- Logo -->
    <div class="auth-logo">
      <div class="auth-logo-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="20" r="1.4"/><circle cx="17" cy="20" r="1.4"/><path d="M2.5 3h2l2.3 11.4a2 2 0 0 0 2 1.6h7.7a2 2 0 0 0 2-1.6L20 7H6"/></svg>
      </div>
      <h2>Good <span>Choice</span></h2>
      <span class="auth-subtitle">Create your staff account</span>
    </div>

    <!-- Error -->
    <% if (error) { %>
      <div class="error-box">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v4M12 17h.01"/><path d="M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z"/></svg>
        <%= error %>
      </div>
    <% } %>

    <form action="/signup" method="POST" id="signupForm">

      <!-- Full Name + Staff ID -->
      <div class="form-row">
        <div class="form-group">
          <label for="fullname">Full Name</label>
          <div class="input-icon-wrap">
            <span class="icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3.5"/><path d="M4.5 20c0-3.6 3.4-6.5 7.5-6.5s7.5 2.9 7.5 6.5"/></svg>
            </span>
            <input
              type="text"
              id="fullname"
              name="fullname"
              placeholder="Buay Khor"
              required
              autocomplete="name"
            />
          </div>
        </div>
        <div class="form-group">
          <label for="staffId">Staff ID <span style="font-weight:400;text-transform:none;font-size:.75rem;color:var(--gc-mid)">(optional)</span></label>
          <div class="input-icon-wrap">
            <span class="icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="8.5" cy="11" r="1.6"/><path d="M6.5 15.5c0-1.4 1-2.2 2-2.2s2 .8 2 2.2"/><path d="M14 10h4M14 13.5h4"/></svg>
            </span>
            <input
              type="text"
              id="staffId"
              name="staffId"
              placeholder="GC-00123"
            />
          </div>
        </div>
      </div>

      <!-- Email -->
      <div class="form-group">
        <label for="email">Work Email</label>
        <div class="input-icon-wrap">
          <span class="icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 7.4 5.6a1 1 0 0 0 1.2 0L20 7"/></svg>
          </span>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="buay@goodchoice.com"
            required
            autocomplete="email"
          />
        </div>
      </div>

      <!-- Phone -->
      <div class="form-group">
        <label for="phone">Phone Number</label>
        <div class="input-icon-wrap">
          <span class="icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h3l1.5 4.5L8 10.5a11 11 0 0 0 5.5 5.5l1.5-1.5 4.5 1.5v3a2 2 0 0 1-2.2 2A17 17 0 0 1 3 7.2 2 2 0 0 1 5 4Z"/></svg>
          </span>
          <input
            type="tel"
            id="phone"
            name="phone"
            placeholder="+256 769 356 930"
            autocomplete="tel"
          />
        </div>
      </div>

      <!-- Password + Confirm -->
      <div class="form-row">
        <div class="form-group">
          <label for="password">Password</label>
          <div class="input-icon-wrap">
            <span class="icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="1.5"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
            </span>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Min. 8 characters"
              required
              minlength="8"
              autocomplete="new-password"
            />
          </div>
        </div>
        <div class="form-group">
          <label for="confirm">Confirm Password</label>
          <div class="input-icon-wrap">
            <span class="icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="1.5"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
            </span>
            <input
              type="password"
              id="confirm"
              name="confirm"
              placeholder="Repeat password"
              required
              autocomplete="new-password"
            />
          </div>
        </div>
      </div>

      <!-- Branch -->
      <div class="form-group">
        <label for="branch">Branch / Store Location</label>
        <select id="branch" name="branch" required>
          <option value="" disabled selected>Select your branch…</option>
          <option value="main">Main Branch – Kampala Road</option>
          <option value="north">North Branch – Gulu Road</option>
          <option value="east">East Branch – Jinja Road</option>
          <option value="west">West Branch – Fort Portal</option>
          <option value="south">South Branch – Masaka Road</option>
        </select>
      </div>

      <!-- Role Selection -->
      <div class="form-group">
        <label>Select Your Role</label>
        <div class="role-grid" id="roleGrid">

          <label class="role-card" for="role-director">
            <input type="radio" name="role" id="role-director" value="director" required />
            <div class="role-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="1.5"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
            </div>
            <div class="role-label">Director</div>
            <div class="role-desc">Full system access &amp; financials</div>
          </label>

          <label class="role-card" for="role-admin">
            <input type="radio" name="role" id="role-admin" value="admin" />
            <div class="role-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8.5 12 4 3 8.5l9 4.5 9-4.5Z"/><path d="M3 8.5V16l9 4.5 9-4.5V8.5"/><path d="M12 13v7.5"/></svg>
            </div>
            <div class="role-label">Admin</div>
            <div class="role-desc">Inventory, pricing &amp; reports</div>
          </label>

          <label class="role-card" for="role-sales">
            <input type="radio" name="role" id="role-sales" value="sales_agent" />
            <div class="role-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h9l3 3v15H6z"/><path d="M9 8h6M9 12h6M9 16h3"/></svg>
            </div>
            <div class="role-label">Sales Agent</div>
            <div class="role-desc">POS &amp; customer transactions</div>
          </label>

        </div>
      </div>

      <!-- Director Access Code field (hidden by default) -->
      <div class="form-group" id="accessCodeGroup" style="display:none;">
        <label for="accessCode">Director Access Code</label>
        <div class="input-icon-wrap">
          <span class="icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="15" r="3.5"/><path d="M10.8 12.2 18 5l2 2-1.5 1.5L20 10l-2 2-1.5-1.5L15 12"/></svg>
          </span>
          <input
            type="password"
            id="accessCode"
            name="accessCode"
            placeholder="Enter director access code"
          />
        </div>
      </div>

      <!-- Terms -->
      <div style="display:flex;align-items:flex-start;gap:.6rem;margin-bottom:1.4rem;margin-top:.4rem;">
        <input type="checkbox" id="terms" name="terms" required style="width:auto;margin-top:.15rem;accent-color:var(--gc-green);" />
        <label for="terms" style="font-size:.82rem;color:var(--gc-mid);cursor:pointer;text-transform:none;letter-spacing:0;">
          I agree to the Good Choice
          <a href="#" style="color:var(--gc-green);font-weight:600;">Terms of Service</a>
          and
          <a href="#" style="color:var(--gc-green);font-weight:600;">Privacy Policy</a>.
        </label>
      </div>

      <button type="submit" class="btn-primary" id="submitBtn">
        Create Account
      </button>

    </form>

    <div class="divider">or</div>

    <div class="auth-switch">
      Already have an account? <a href="/login">Sign in here</a>
    </div>

  </div>
</div>

<script>
  // Role card selection highlight
  const roleCards = document.querySelectorAll('.role-card');
  const accessCodeGroup = document.getElementById('accessCodeGroup');
  const accessCodeInput = document.getElementById('accessCode');

  roleCards.forEach(card => {
    const radio = card.querySelector('input[type="radio"]');
    card.addEventListener('click', () => {
      roleCards.forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');

      // Show access code field only for director
      if (radio.value === 'director') {
        accessCodeGroup.style.display = 'block';
        accessCodeInput.required = true;
      } else {
        accessCodeGroup.style.display = 'none';
        accessCodeInput.required = false;
        accessCodeInput.value = ''; // clear if switching away
      }
    });
  });

  // Password match validation
  document.getElementById('signupForm').addEventListener('submit', function(e) {
    const pw = document.getElementById('password').value;
    const cf = document.getElementById('confirm').value;
    if (pw !== cf) {
      e.preventDefault();
      alert('Passwords do not match. Please try again.');
    }
  });
</script>

<%- include('partials/footer') %>
