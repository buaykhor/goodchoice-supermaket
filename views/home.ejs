<%- include('partials/header', { title: 'Welcome' }) %>

<!-- HERO -->
<section class="hero">
  <div class="hero-tag">🌿 Smart. Fresh. Local.</div>
  <h1>Manage Your Store<br>the <span>Good Choice</span> Way</h1>
  <p class="hero-sub">
    A complete retail management platform built for modern supermarkets —
    from inventory and sales to staff roles and daily reporting.
  </p>
  <div class="hero-actions">
    <a href="/signup" class="btn-hero-primary">🚀 Get Started Free</a>
    <a href="/login" class="btn-hero-outline">🔑 Staff Login</a>
  </div>
</section>

<!-- STATS BAR -->
<div class="stats-bar">
  <div class="stat">
    <div class="stat-num">12,400+</div>
    <div class="stat-label">Products Tracked</div>
  </div>
  <div class="stat">
    <div class="stat-num">99.9%</div>
    <div class="stat-label">Uptime</div>
  </div>
  <div class="stat">
    <div class="stat-num">3 Roles</div>
    <div class="stat-label">Director · Admin · Sales</div>
  </div>
  <div class="stat">
    <div class="stat-num">Real-time</div>
    <div class="stat-label">Inventory Updates</div>
  </div>
</div>

<!-- FEATURES -->
<section class="features">
  <div class="section-head">
    <div class="section-eyebrow">What We Offer</div>
    <h2>Everything Your Store Needs</h2>
  </div>
  <div class="features-grid">
    <div class="feature-card">
      <div class="feature-icon">📦</div>
      <h3>Inventory Management</h3>
      <p>Track stock levels, expiry dates, and reorder points across all product categories in real time.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">📊</div>
      <h3>Sales Analytics</h3>
      <p>Daily, weekly, and monthly sales dashboards that reveal what's moving and what isn't.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">👥</div>
      <h3>Staff Management</h3>
      <p>Assign roles, manage shifts, and track performance across your entire supermarket team.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🧾</div>
      <h3>POS Integration</h3>
      <p>Sync seamlessly with your point-of-sale system for live transaction records and receipts.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🔔</div>
      <h3>Smart Alerts</h3>
      <p>Low stock warnings, price change notifications, and daily summary reports sent automatically.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🔒</div>
      <h3>Role-Based Access</h3>
      <p>Granular permissions ensure each staff member sees only what's relevant to their role.</p>
    </div>
  </div>
</section>

<!-- ROLES SECTION -->
<section class="roles-section">
  <div class="section-head">
    <div class="section-eyebrow" style="color:var(--gc-gold)">Access Levels</div>
    <h2 style="color:#fff">Built for Every Team Member</h2>
  </div>
  <div class="roles-grid">
    <div class="role-pill">
      <div class="rp-icon">👑</div>
      <h4>Director</h4>
      <p>Full oversight. View financials, approve budgets, manage all staff and system settings.</p>
    </div>
    <div class="role-pill">
      <div class="rp-icon">🗂️</div>
      <h4>Admin</h4>
      <p>Day-to-day operations. Manage inventory, pricing, suppliers, and generate reports.</p>
    </div>
    <div class="role-pill">
      <div class="rp-icon">🛍️</div>
      <h4>Sales Agent</h4>
      <p>Process transactions, handle customer requests, and manage checkout operations.</p>
    </div>
  </div>
</section>

<!-- CTA STRIP -->
<section class="cta-strip">
  <h2>Ready to Run a Smarter Store?</h2>
  <p>Join the Good Choice platform today — setup takes under 5 minutes.</p>
  <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
    <a href="/signup" class="btn-primary" style="width:auto;padding:.85rem 2.5rem;">Create Your Account</a>
    <a href="/login" class="btn-outline" style="padding:.85rem 2.5rem;">Staff Login</a>
  </div>
</section>

<%- include('partials/footer') %>
